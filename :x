server {
    listen 443 ssl;
    server_name logistics.aasiiitech.com;

    # SSL (managed by Certbot)
    ssl_certificate /etc/letsencrypt/live/logistics.aasiiitech.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/logistics.aasiiitech.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Reverse proxy to Docker container
    location / {
        proxy_pass http://127.0.0.1:3000;

        proxy_http_version 1.1;

        # WebSocket support (important for React/Vite/Next apps if used)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Forward client info
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

	# IMPORTANT for SPA routing
	proxy_intercept_errors on;
	error_page 404 = /index.html;	
    }
}

# Redirect HTTP → HTTPS
server {
    listen 80;
    server_name logistics.aasiiitech.com;

    return 301 https://$host$request_uri;
}
